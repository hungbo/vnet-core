{
  "$schema": "https://opencode.ai/config.json",

  "command": {
    "dev-backend": {
      "template": "Start the backend dev server. In `backend/`, run `air` (hot-reload) or `go run ./cmd/server`.",
      "description": "Dev backend (Go/Gin via Air)"
    },
    "dev-admin": {
      "template": "Start the Vue 3 admin dev server. In `admin/`, run `pnpm dev` (Vite on :3000, proxies /api → localhost:8080).",
      "description": "Dev admin (Vue 3/Soybean)"
    },
    "test-backend": {
      "template": "Run all Go backend tests: `go test ./...` from `backend/`.",
      "description": "Test Go backend"
    },
    "lint-backend": {
      "template": "Run golangci-lint on the Go backend: `golangci-lint run` from `backend/`.",
      "description": "Lint Go backend"
    },
    "lint-admin": {
      "template": "Lint and type-check the Vue 3 admin: `pnpm lint` then `pnpm typecheck` from `admin/`.",
      "description": "Lint + typecheck admin"
    },
    "migrate": {
      "template": "Run database migrations: `go run ./cmd/migrate` from `backend/`.",
      "description": "DB migrations"
    },
    "seed": {
      "template": "Seed database with default accounts (admin/admin123, manager/admin123, staff/admin123): `go run ./cmd/seed` from `backend/`.",
      "description": "Seed DB accounts"
    },
    "build-server": {
      "template": "Build production server binary with embedded admin UI. Run `bash scripts/build-server.sh` from project root. Accepts $VERSION as arg.",
      "description": "Build server + embed admin"
    },
    "build-admin": {
      "template": "Build the admin frontend for production: `pnpm build` from `admin/`.",
      "description": "Build admin (production)"
    }
  },

  "instructions": ["AGENTS.md"]
}
